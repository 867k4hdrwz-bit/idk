{
  "name": "minecraft-pocket-remote",
  "version": "0.1.0",
  "description": "Local Safari/PWA-style controller for playing Minecraft Java from a phone",
  "main": "server/index.js",
  "type": "module",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "build": "npm run build:client",
    "build:client": "esbuild client/index.ts --bundle --outfile=public/bundle.js --sourcemap",
    "watch": "npm run build:client -- --watch"
  },
  "keywords": [
    "minecraft",
    "remote",
    "controller",
    "phone",
    "pwa"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "robotjs": "^0.6.0",
    "uuid": "^9.0.1",
    "ws": "^8.15.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/robotjs": "^0.6.4",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "esbuild": "^0.19.10",
    "typescript": "^5.3.3"
  }
}
